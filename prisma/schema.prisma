// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ingredient {
  id           String       @id @default(cuid())
  name         String
  unit         String       // e.g., "kg", "gram", "bungkus"
  pricePerUnit Float        // Price per unit defined above
  stock        Float        @default(0)
  minStock     Float        @default(0)
  recipes      RecipeItem[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model MenuItem {
  id           String       @id @default(cuid())
  name         String
  description  String?
  basePrice    Float        // Selling price
  recipes      RecipeItem[]
  sales        Sale[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model RecipeItem {
  id            String     @id @default(cuid())
  menuItem      MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  menuItemId    String
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id])
  ingredientId  String
  quantity      Float      // Quantity of ingredient used for this menu item
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Sale {
  id         String   @id @default(cuid())
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId String
  quantity   Int
  totalPrice Float
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  category    String?  // e.g., "Bensin", "Gas", "Parkir"
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
